/*
========================================================================================
  nextflow.config
  TCR Autoreactivity Pipeline — Lifebit CloudOS compatible
========================================================================================
*/

// ─── DEFAULT PARAMETERS ──────────────────────────────────────────────────────
params {
    // Input: 'GENERATE' triggers synthetic data generation, or supply a CSV path
    input_csv   = 'GENERATE'

    // Output directory
    outdir      = 'results'

    // Synthetic data sizes (matches thesis approx. class balance)
    n_ms        = 300
    n_sle       = 150
    n_hc        = 600
    n_lab       = 50

    // Model hyperparameters
    test_size   = 0.2
    cv_folds    = 5
    seed        = 42
}

// ─── DOCKER (used locally and on CloudOS) ────────────────────────────────────
docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g)'
}

// ─── PROCESS DEFAULTS ────────────────────────────────────────────────────────
process {
    container = 'quay.io/luischanlifebit/tcr-autoreactivity:latest'

    withName: 'GENERATE_SYNTHETIC_DATA' {
        cpus   = 1
        memory = '2 GB'
    }
    withName: 'PREPROCESS' {
        cpus   = 1
        memory = '2 GB'
    }
    withName: 'TRAIN_MODEL' {
        cpus   = 2
        memory = '4 GB'
    }
    withName: 'EVALUATE_MODEL' {
        cpus   = 1
        memory = '2 GB'
    }
    withName: 'FEATURE_IMPORTANCE' {
        cpus   = 2
        memory = '4 GB'
    }
    withName: 'SCORE_LAB_PANEL' {
        cpus   = 1
        memory = '2 GB'
    }
    withName: 'SHINY_REPORT' {
        cpus   = 1
        memory = '2 GB'
    }
}

// ─── EXECUTION PROFILES ──────────────────────────────────────────────────────
profiles {

    // Local development
    local {
        docker.enabled = true
        process.executor = 'local'
    }

    // Lifebit CloudOS (AWS batch via CloudOS Advanced Analytics)
    cloudos {
        docker.enabled   = true
        process.executor = 'awsbatch'
        aws {
            region = 'eu-west-1'  // update to match your CloudOS deployment
        }
        process {
            queue = 'YOUR_CLOUDOS_QUEUE'  // set in CloudOS pipeline import
        }
    }

    // CI testing with minimal data
    test {
        params {
            n_ms   = 30
            n_sle  = 15
            n_hc   = 60
            n_lab  = 10
        }
        docker.enabled = true
    }
}

// ─── REPORTING ────────────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.svg"
}

manifest {
    name            = 'tcr-autoreactivity'
    author          = 'Luis Chan'
    description     = 'Interpretable ML pipeline for autoreactive TCR discovery'
    version         = '1.0.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}
