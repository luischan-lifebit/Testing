/*
========================================================================================
  nextflow.config — TCR Autoreactivity Pipeline
  Uses public Docker images — no custom build required
========================================================================================
*/

params {
    input_csv = 'GENERATE'
    outdir    = 'results'
    n_ms      = 300
    n_sle     = 150
    n_hc      = 600
    n_lab     = 50
    test_size = 0.2
    cv_folds  = 5
    seed      = 42
}

docker {
    enabled = true
}

process {

    // Public Python ML image — has numpy, pandas, scikit-learn, xgboost, matplotlib
    withName: 'GENERATE_SYNTHETIC_DATA|PREPROCESS|TRAIN_MODEL|EVALUATE_MODEL|FEATURE_IMPORTANCE|SCORE_LAB_PANEL' {
        container = 'community.wave.seqera.io/library/scikit-learn_xgboost_matplotlib_pandas:latest'
        cpus      = 2
        memory    = '4 GB'
    }

    // Public R Shiny image — has shiny, ggplot2, dplyr, tidyverse
    withName: 'SHINY_REPORT' {
        container = 'rocker/shiny-verse:latest'
        cpus      = 1
        memory    = '2 GB'
    }
}

profiles {
    local {
        docker.enabled   = true
        process.executor = 'local'
    }
    test {
        params {
            n_ms  = 30
            n_sle = 15
            n_hc  = 60
            n_lab = 10
        }
        docker.enabled = true
    }
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.svg"
}

manifest {
    name            = 'tcr-autoreactivity'
    author          = 'Luis Chan'
    description     = 'Interpretable ML pipeline for autoreactive TCR discovery'
    version         = '1.0.0'
    nextflowVersion = '>=23.04.0'
    mainScript      = 'main.nf'
}
